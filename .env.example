AD_SCANNER_INPUT=sample-websites.csv
AD_SCANNER_OUTPUT=results/matches.csv
AD_SCANNER_PATTERN=doubleclick.net
AD_SCANNER_MAX_RANK=1000
AD_SCANNER_TIMEOUT_MS=8000
AD_SCANNER_SETTLE_MS=1500
AD_SCANNER_CONCURRENCY=3
AD_SCANNER_HEADED=false
AD_SCANNER_DISABLE_BROWSER_SANDBOX=false

# Optional Puppeteer override when Chromium is managed outside npm.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
